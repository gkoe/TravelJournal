<Window x:Class="TravelJournal.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
        xmlns:uiM="clr-namespace:Wpf.Ui.Markup;assembly=Wpf.Ui"
        xmlns:vm="clr-namespace:TravelJournal.Wpf.ViewModels"
        xmlns:views="clr-namespace:TravelJournal.Wpf.Views"
        xmlns:conv="clr-namespace:TravelJournal.Wpf.Converters"
        xmlns:controls="clr-namespace:TravelJournal.Wpf.Controls"
        Title="TravelJournal" Icon="/TravelJournal.ico"
        Width="1600" Height="900" MinWidth="700" MinHeight="500"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <conv:PhotoStateToBrushConverter      x:Key="PhotoStateToBrushConverter"/>
        <conv:NullableDoubleToStringConverter x:Key="NullableDoubleToStringConverter"/>
        <conv:EnumToBoolConverter             x:Key="EnumToBoolConverter"/>
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>

        <!-- ── Galerie-Listen-Templates ────────────────────── -->

        <DataTemplate x:Key="PhotoListTemplate" DataType="{x:Type vm:PhotoViewModel}">
            <Border BorderThickness="2" CornerRadius="3" Margin="2,2,2,0"
                    BorderBrush="{Binding State, Converter={StaticResource PhotoStateToBrushConverter}}"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Auswählen (1)"
                                  Command="{Binding PlacementTarget.Tag.SetStateSelectedCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Abwählen (2)"
                                  Command="{Binding PlacementTarget.Tag.SetStateDeselectedCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Offen (0)"
                                  Command="{Binding PlacementTarget.Tag.SetStateNoneCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Startfolie (3)"
                                  Command="{Binding PlacementTarget.Tag.SetStateStartCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Schlussfolie (4)"
                                  Command="{Binding PlacementTarget.Tag.SetStateEndCommand,
                                            RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid Height="72">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Image Grid.Column="0" Source="{Binding Thumbnail}"
                           Stretch="UniformToFill" Width="96" Height="72"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <StackPanel Grid.Column="1" Margin="6,4,4,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Filename}"
                                   TextTrimming="CharacterEllipsis"
                                   FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Text="{Binding DateTime, StringFormat='{}{0:dd.MM.  HH:mm}'}"
                                   FontSize="10" Opacity="0.7"/>
                        <TextBlock Text="{Binding Location}"
                                   FontSize="10" Opacity="0.7"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Badges oben rechts -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                VerticalAlignment="Top" Orientation="Horizontal" Margin="0,3,3,0">
                        <Border Background="#1565C0" CornerRadius="2" Padding="3,1" Margin="2,0,0,0"
                                Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="NEU" Foreground="White" FontSize="8" FontWeight="Bold"/>
                        </Border>
                        <Border Background="#E65100" CornerRadius="2" Padding="3,1" Margin="2,0,0,0"
                                Visibility="{Binding IsMissing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="FEHLT" Foreground="White" FontSize="8" FontWeight="Bold"/>
                        </Border>
                        <Border Background="{StaticResource AccentBrush}" CornerRadius="2" Padding="3,1" Margin="2,0,0,0"
                                Visibility="{Binding IsMapPhoto, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="KARTE" Foreground="White" FontSize="8" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Rotation-Badge unten rechts -->
                    <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Background="{StaticResource AccentBrush}" CornerRadius="2"
                            Padding="3,1" Margin="0,0,3,3"
                            Visibility="{Binding HasPendingRotation, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="↻" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>

                    <!-- State-Icon unten links -->
                    <Border Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                            Background="#88000000" CornerRadius="0,3,0,0" Padding="3,1">
                        <TextBlock FontSize="11" Foreground="White">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State}" Value="Selected">
                                            <Setter Property="Text" Value="✓"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="Deselected">
                                            <Setter Property="Text" Value="✗"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="None">
                                            <Setter Property="Text" Value="○"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="Start">
                                            <Setter Property="Text" Value="▶"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State}" Value="End">
                                            <Setter Property="Text" Value="■"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

<DataTemplate x:Key="HeicListTemplate" DataType="{x:Type vm:HeicItemViewModel}">
            <Border BorderThickness="2" CornerRadius="3" Margin="2,2,2,0"
                    BorderBrush="#FF8F00">
                <Grid Height="72">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="96"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#2A2200">
                        <TextBlock Text="HEIC" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="14" FontWeight="Bold" Foreground="#FF8F00"/>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="6,4,4,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Filename}"
                                   TextTrimming="CharacterEllipsis"
                                   FontWeight="SemiBold" FontSize="12"/>
                    </StackPanel>

                    <!-- HEIC-Badge oben rechts -->
                    <Border Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#FF8F00" CornerRadius="2"
                            Padding="3,1" Margin="0,3,3,0">
                        <TextBlock Text="HEIC" Foreground="White" FontSize="8" FontWeight="Bold"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- ── Listen-Selektor ── -->

        <views:GalleryItemTemplateSelector x:Key="ListTemplateSelector"
            PhotoTemplate="{StaticResource PhotoListTemplate}"
            HeicTemplate="{StaticResource HeicListTemplate}"/>

        <!-- ── Detail-Templates ─────────────────────────────── -->

        <DataTemplate x:Key="PhotoDetailTemplate" DataType="{x:Type vm:PhotoViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#111111">
                    <Grid>
                        <Image Source="{Binding DetailImage}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.LayoutTransform>
                                <RotateTransform Angle="{Binding PendingRotation}"/>
                            </Image.LayoutTransform>
                        </Image>
                        <controls:CropOverlay
                            ImagePixelWidth="{Binding PixelWidth}"
                            ImagePixelHeight="{Binding PixelHeight}"
                            SelectedCropRect="{Binding DataContext.CropRect,
                                               RelativeSource={RelativeSource AncestorType=Window}}"
                            ConfirmCommand="{Binding DataContext.ConfirmCropCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Padding="16,10,16,10"
                        Background="{StaticResource InfoPanelBackgroundBrush}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource SeparatorBrush}">
                    <StackPanel>

                        <TextBlock Text="TITEL" Style="{StaticResource DetailLabelText}"/>
                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="16" FontWeight="SemiBold"
                                 Margin="0,2,0,6">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Titel eingeben…"
                                                                       Foreground="#AAAAAA"
                                                                       FontStyle="Italic"
                                                                       FontSize="16"
                                                                       Margin="7,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="ORT" Style="{StaticResource DetailLabelText}"/>
                        <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12"
                                 Margin="0,2,0,8">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left" AlignmentY="Center">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Ort eingeben…"
                                                                       Foreground="#AAAAAA"
                                                                       FontStyle="Italic"
                                                                       FontSize="12"
                                                                       Margin="7,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>

                        <TextBlock Text="BESCHREIBUNG" Style="{StaticResource DetailLabelText}"/>
                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MaxHeight="100"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="12"
                                 Margin="0,2,0,8"/>

                        <TextBlock Style="{StaticResource DetailMetaText}" TextWrapping="Wrap" Margin="0,0,0,8">
                            <Run Text="{Binding DateTimeFormatted, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding CoordinatesFormatted, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding AltitudeFormatted, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding PixelDimensionsFormatted, Mode=OneWay}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding FileSizeFormatted, Mode=OneWay}"/>
                        </TextBlock>

                        <WrapPanel>
                            <TextBlock Text="STATUS" Style="{StaticResource DetailLabelText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton Content="Ausgewählt" GroupName="DetailState"
                                         Margin="0,0,10,0" FontSize="11"
                                         IsChecked="{Binding State, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Selected}"/>
                            <RadioButton Content="Abgewählt" GroupName="DetailState"
                                         Margin="0,0,10,0" FontSize="11"
                                         IsChecked="{Binding State, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Deselected}"/>
                            <RadioButton Content="Offen" GroupName="DetailState"
                                         Margin="0,0,10,0" FontSize="11"
                                         IsChecked="{Binding State, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=None}"/>
                            <RadioButton Content="▶ Start" GroupName="DetailState"
                                         Margin="0,0,10,0" FontSize="11"
                                         IsChecked="{Binding State, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Start}"/>
                            <RadioButton Content="■ Ende" GroupName="DetailState"
                                         FontSize="11"
                                         IsChecked="{Binding State, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=End}"/>
                        </WrapPanel>

                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

<DataTemplate x:Key="HeicDetailTemplate" DataType="{x:Type vm:HeicItemViewModel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1A1500">
                    <TextBlock Text="HEIC" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontSize="64" FontWeight="Bold" Foreground="#FF8F00" Opacity="0.3"/>
                </Border>

                <Border Grid.Row="1"
                        Padding="16,10,16,10"
                        Background="{StaticResource InfoPanelBackgroundBrush}"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource SeparatorBrush}">
                    <StackPanel>
                        <TextBlock Text="{Binding Filename}"
                                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <TextBlock Text="Dieses Bild liegt im HEIC/HEIF-Format vor und kann nicht direkt angezeigt werden."
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.7"/>
                        <TextBlock Text="Klicken Sie auf 'HEIC konvertieren' um es in JPEG umzuwandeln."
                                   FontSize="12" TextWrapping="Wrap" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- ── Detail-Selektor ── -->

        <views:GalleryItemTemplateSelector x:Key="DetailTemplateSelector"
            PhotoTemplate="{StaticResource PhotoDetailTemplate}"
            HeicTemplate="{StaticResource HeicDetailTemplate}"/>

    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F5"                    Command="{Binding RescanCommand}"/>
        <KeyBinding Key="M" Modifiers="Control" Command="{Binding GenerateMapsCommand}"/>
        <KeyBinding Key="P" Modifiers="Control" Command="{Binding StartPresentationCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ── Statusleiste ── -->
        <StatusBar DockPanel.Dock="Bottom" Background="{StaticResource SidebarBrush}"
                   BorderThickness="0,1,0,0" BorderBrush="{StaticResource SeparatorBrush}">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" FontSize="12"/>
            </StatusBarItem>
            <Separator Visibility="{Binding BackgroundActivityText,
                           Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
            <StatusBarItem>
                <TextBlock Text="{Binding BackgroundActivityText}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12"
                           Visibility="{Binding BackgroundActivityText,
                               Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar IsIndeterminate="True" Width="80" Height="10"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Haupt-Grid: 3 Spalten ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="290" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ════════════════════════════════════════════
                 SPALTE 0 — Bearbeitungsfunktionen
                 ════════════════════════════════════════════ -->
            <DockPanel Grid.Column="0" Background="{StaticResource SidebarBrush}">

                <!-- Aktueller Ordner -->
                <TextBlock DockPanel.Dock="Bottom"
                           Style="{StaticResource ToolbarHintText}"
                           Text="{Binding CurrentFolder, FallbackValue='Kein Ordner geöffnet'}"
                           TextWrapping="Wrap" Margin="12,6" Opacity="0.7"
                           ToolTip="{Binding CurrentFolder}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                  <StackPanel Margin="12">

                    <!-- ===== VORBEREITUNG ===== -->
                    <TextBlock Style="{StaticResource ToolbarSectionHeader}" Text="Vorbereitung"/>
                    <ui:Button Content="Ordner öffnen…"
                               Icon="{uiM:SymbolIcon FolderOpen24}"
                               Command="{Binding OpenFolderCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                    <ui:Button Content="Neu scannen"
                               Icon="{uiM:SymbolIcon ArrowSync24}"
                               Command="{Binding RescanCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                    <ui:Button Content="HEIC importieren"
                               Icon="{uiM:SymbolIcon ArrowImport24}"
                               Command="{Binding ConvertHeicCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"/>

                    <Separator Margin="0,12"/>

                    <!-- ===== BEARBEITUNG ===== -->
                    <TextBlock Style="{StaticResource ToolbarSectionHeader}" Text="Bearbeitung"/>

                    <TextBlock Style="{StaticResource ToolbarSubsectionHeader}" Text="Auswahl"/>
                    <ui:Button Content="Alle Offenen auswählen"
                               Icon="{uiM:SymbolIcon CheckboxChecked24}"
                               Command="{Binding SelectAllOpenCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"/>
                    <ui:Button Content="Alle offenen abwählen"
                               Icon="{uiM:SymbolIcon CheckmarkSquare24}"
                               Command="{Binding DeselectAllOpenCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                    <TextBlock Style="{StaticResource ToolbarSubsectionHeader}" Text="Bild bearbeiten"/>
                    <ui:Button Content="Fotos umbenennen"
                               Icon="{uiM:SymbolIcon Rename24}"
                               Command="{Binding RenamePhotosCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"/>

                    <ui:CardExpander Header="Namensschema" IsExpanded="False" Margin="0,0,0,8">
                      <StackPanel>
                        <TextBlock Style="{StaticResource ToolbarLabelText}" Text="Präfix (optional)" Margin="0,8,0,2"/>
                        <TextBox Text="{Binding RenamePrefix, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Fester Text, der über den Platzhalter {prefix} eingesetzt wird (z.B. rhodos)."
                                 Margin="0,0,0,8"/>

                        <TextBlock Style="{StaticResource ToolbarLabelText}" Text="Vorlage" Margin="0,0,0,2"/>
                        <TextBox Text="{Binding RenameTemplate, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Platzhalter: {prefix}, {datetime} (YYMMDD_hhmmss), {ort}"
                                 Margin="0,0,0,4"/>
                        <TextBlock Style="{StaticResource ToolbarHintText}"
                                   TextWrapping="Wrap" Margin="0,0,0,6"
                                   Text="Platzhalter: {prefix} · {datetime} (YYMMDD_hhmmss) · {ort}"/>
                        <TextBlock Style="{StaticResource ToolbarHintText}" TextWrapping="Wrap">
                          <Run Text="Beispiel: "/>
                          <Run Text="{Binding RenamePreview, Mode=OneWay}" FontWeight="SemiBold"/>
                        </TextBlock>
                      </StackPanel>
                    </ui:CardExpander>

                    <TextBlock Style="{StaticResource ToolbarHintText}"
                               Text="Tasten: 1/2/0 Status, Leertaste zyklisch, L/R drehen, S speichern"
                               Margin="0,0,0,8"/>

                    <TextBlock Style="{StaticResource ToolbarSubsectionHeader}" Text="Filter"/>
                    <UniformGrid Columns="2" Margin="0,0,0,8">
                      <RadioButton Content="Alle"       GroupName="Filter" Style="{StaticResource FilterRadioStyle}"
                                   IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=All}"/>
                      <RadioButton Content="Offen"      GroupName="Filter" Style="{StaticResource FilterRadioStyle}"
                                   IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Open}"/>
                      <RadioButton Content="Ausgewählt" GroupName="Filter" Style="{StaticResource FilterRadioStyle}"
                                   IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Selected}"/>
                      <RadioButton Content="Abgewählt"  GroupName="Filter" Style="{StaticResource FilterRadioStyle}"
                                   IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Deselected}"/>
                      <RadioButton Content="Neu"        GroupName="Filter" Style="{StaticResource FilterRadioStyle}"
                                   IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=New}"/>
                      <RadioButton Content="Karten"     GroupName="Filter" Style="{StaticResource FilterRadioStyle}"
                                   IsChecked="{Binding ActiveFilter, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Maps}"/>
                    </UniformGrid>

                    <TextBlock Style="{StaticResource ToolbarSubsectionHeader}" Text="Orte"/>
                    <ui:Button Content="{Binding GeocodingButtonText}"
                               Icon="{uiM:SymbolIcon Location24}"
                               Command="{Binding ToggleGeocodingCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"
                               ToolTip="Ermittelt für alle ausgewählten Fotos mit GPS-Daten den Ortsnamen via OpenStreetMap. Ein zweiter Klick bricht die laufende Abfrage ab."/>
                    <ui:Button Content="Alle Orte löschen"
                               Icon="{uiM:SymbolIcon Delete24}"
                               Command="{Binding ClearAllLocationsCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,8"
                               ToolTip="Entfernt den ermittelten/eingegebenen Ort bei allen Fotos. Karten bleiben unangetastet."/>

                    <ui:CardExpander Header="Karten" IsExpanded="False" Margin="0,0,0,8">
                      <StackPanel>
                        <TextBlock Style="{StaticResource ToolbarLabelText}" Text="Stil" Margin="0,8,0,2"/>
                        <ComboBox ItemsSource="{Binding AvailableMapStyles}"
                                  DisplayMemberPath="DisplayLabel"
                                  SelectedValuePath="Id"
                                  SelectedValue="{Binding SelectedMapStyleId, Mode=TwoWay}"
                                  ToolTip="Wirkt sich auf neu generierte Karten aus."
                                  Margin="0,0,0,8"/>

                        <TextBlock Style="{StaticResource ToolbarLabelText}" Text="Sprache"/>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                  ToolTip="Sprache der Ortsbeschriftungen auf der Karte."
                                  Margin="0,0,0,8"/>

                        <TextBlock Style="{StaticResource ToolbarLabelText}">
                          <Run Text="Rand"/>
                          <Run Text="{Binding BoundsPaddingPercent, StringFormat=' ({0} %)'}"/>
                        </TextBlock>
                        <Slider Minimum="0" Maximum="40" TickFrequency="2" IsSnapToTickEnabled="True"
                                Value="{Binding BoundsPaddingPercent, Mode=TwoWay}"
                                ToolTip="Wie viel freier Rand um die Route herum dargestellt wird."
                                Margin="0,0,0,12"/>

                        <ui:Button Content="Karten generieren"
                                   Icon="{uiM:SymbolIcon Map24}"
                                   Command="{Binding GenerateMapsCommand}"
                                   Appearance="Primary"
                                   HorizontalAlignment="Stretch"
                                   ToolTip="Erzeugt Karten für jeden erkannten Stopp. (Strg+M)&#10;Aktiv, sobald für mindestens ein ausgewähltes Foto ein Ort ermittelt wurde."/>
                        <TextBlock Style="{StaticResource ToolbarHintText}"
                                   Text="Aktiv, sobald für mindestens ein ausgewähltes Foto ein Ort ermittelt wurde. Bestehende Karten werden ersetzt."
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                      </StackPanel>
                    </ui:CardExpander>

                    <Separator Margin="0,12"/>

                    <!-- ===== AUSGABE ===== -->
                    <TextBlock Style="{StaticResource ToolbarSectionHeader}" Text="Ausgabe"/>
                    <ui:Button Content="Präsentation starten"
                               Icon="{uiM:SymbolIcon Play24}"
                               Command="{Binding StartPresentationCommand}"
                               Appearance="Primary"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"
                               ToolTip="Spielt ausgewählte Fotos und Karten in chronologischer Reihenfolge im Vollbild ab. (Strg+P)"/>
                    <ui:Button Content="Web-Präsentation exportieren"
                               Icon="{uiM:SymbolIcon ShareScreenStart24}"
                               Command="{Binding ExportWebPresentationCommand}"
                               HorizontalAlignment="Stretch" Margin="0,0,0,4"
                               ToolTip="Erzeugt einen lokal lauffähigen Web-Präsentationsordner."/>
                    <ui:Button Content="Fotos exportieren"
                               Icon="{uiM:SymbolIcon Copy24}"
                               Command="{Binding ExportPhotosCommand}"
                               HorizontalAlignment="Stretch"
                               ToolTip="Kopiert alle ausgewählten Fotos in einen Zielordner."/>

                  </StackPanel>
                </ScrollViewer>

            </DockPanel>

            <!-- Trennlinie 1 -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ════════════════════════════════════════════
                 SPALTE 2 — Foto-/Karten-Liste
                 ════════════════════════════════════════════ -->
            <ListBox x:Name="PhotoList"
                     Grid.Column="2"
                     ItemsSource="{Binding GalleryItemsView}"
                     SelectedItem="{Binding SelectedGalleryItem, Mode=TwoWay}"
                     ItemTemplateSelector="{StaticResource ListTemplateSelector}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingStackPanel.IsVirtualizing="True"
                     VirtualizingStackPanel.VirtualizationMode="Recycling"
                     Background="{StaticResource SidebarBrush}" BorderThickness="0"
                     SelectionChanged="PhotoList_SelectionChanged">
                <ListBox.InputBindings>
                    <KeyBinding Key="Space"   Command="{Binding CycleSelectedPhotoStateCommand}"/>
                    <KeyBinding Key="D1"      Command="{Binding SetStateSelectedCommand}"/>
                    <KeyBinding Key="D2"      Command="{Binding SetStateDeselectedCommand}"/>
                    <KeyBinding Key="D0"      Command="{Binding SetStateNoneCommand}"/>
                    <KeyBinding Key="D3"      Command="{Binding SetStateStartCommand}"/>
                    <KeyBinding Key="D4"      Command="{Binding SetStateEndCommand}"/>
                    <KeyBinding Key="NumPad1" Command="{Binding SetStateSelectedCommand}"/>
                    <KeyBinding Key="NumPad2" Command="{Binding SetStateDeselectedCommand}"/>
                    <KeyBinding Key="NumPad0" Command="{Binding SetStateNoneCommand}"/>
                    <KeyBinding Key="NumPad3" Command="{Binding SetStateStartCommand}"/>
                    <KeyBinding Key="NumPad4" Command="{Binding SetStateEndCommand}"/>
                    <KeyBinding Key="L"       Command="{Binding RotateLeftCommand}"/>
                    <KeyBinding Key="R"       Command="{Binding RotateRightCommand}"/>
                    <KeyBinding Key="S"       Command="{Binding SaveRotationCommand}"/>
                    <KeyBinding Key="Delete"  Command="{Binding DeleteSelectedPhotoCommand}"/>
                </ListBox.InputBindings>
            </ListBox>

            <!-- Trennlinie 2 -->
            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource SeparatorBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ════════════════════════════════════════════
                 SPALTE 4 — Detail-Bereich
                 ════════════════════════════════════════════ -->
            <Grid Grid.Column="4">

                <!-- Hinweis bei keiner Auswahl -->
                <TextBlock Text="Kein Element ausgewählt"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#BBBBBB" FontSize="16">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedGalleryItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Detail-Inhalt (Foto oder Karte) -->
                <ContentControl Content="{Binding SelectedGalleryItem}"
                                ContentTemplateSelector="{StaticResource DetailTemplateSelector}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Stretch">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedGalleryItem}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
