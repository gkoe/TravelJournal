<Window x:Class="TravelJournal.Wpf.Views.PresentationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TravelJournal.Wpf.ViewModels"
        Title="Präsentation"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="Black"
        Cursor="None"
        ShowInTaskbar="False"
        Topmost="True">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding StopCommand}"/>
        <KeyBinding Key="Space"  Command="{Binding TogglePauseCommand}"/>
        <KeyBinding Key="Right"  Command="{Binding NextCommand}"/>
        <KeyBinding Key="Left"   Command="{Binding PreviousCommand}"/>
    </Window.InputBindings>

    <Grid>

        <!-- Hauptbild -->
        <Image Source="{Binding CurrentImageSource}"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"/>

        <!-- Info-Overlay unten (initial unsichtbar, wird per Animation eingeblendet) -->
        <Border x:Name="OverlayPanel"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Stretch"
                Padding="48,32"
                Opacity="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#CC000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>

                <!-- Beschreibung — ersetzt Ort und Datum wenn gesetzt -->
                <TextBlock Text="{Binding OverlayDescription}"
                           FontSize="38"
                           FontWeight="SemiBold"
                           Foreground="White"
                           TextWrapping="Wrap"
                           Visibility="{Binding OverlayDescriptionVisibility}"/>

                <!-- Ortsname — nur sichtbar wenn keine Beschreibung vorhanden -->
                <TextBlock Text="{Binding OverlayLocation}"
                           FontSize="44"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Visibility="{Binding OverlayLocationVisibility}"
                           Margin="0,0,0,8"/>

                <!-- Datum/Zeit — größer wenn kein Ort, unsichtbar wenn Beschreibung gesetzt -->
                <TextBlock Text="{Binding OverlayDateTime}"
                           Foreground="#EEEEEE"
                           Visibility="{Binding OverlayDateTimeVisibility}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="26"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OverlayLocationVisibility}"
                                             Value="Collapsed">
                                    <Setter Property="FontSize" Value="38"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

            </StackPanel>
        </Border>

        <!-- Dezenter Hinweis oben rechts (initial sichtbar, blendet nach 3 s aus) -->
        <TextBlock x:Name="HintText"
                   Text="Esc: beenden  ·  Space: Pause  ·  ← →: Blättern"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Right"
                   Margin="32"
                   FontSize="13"
                   Foreground="#80FFFFFF"
                   Opacity="1"/>

    </Grid>
</Window>
