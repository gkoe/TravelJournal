{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "TravelJournal": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "%LOCALAPPDATA%/TravelJournal/logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "MapTiler": {
    "ApiKey": "DEIN_KEY_HIER"
  },
  "Nominatim": {
    "ContactEmail": "deine@email.at"
  },
  "MapRendering": {
    "StyleId": "outdoor-v2",
    "Language": "de",
    "BoundsPaddingFraction": 0.12,
    "TargetWidthPx": 1600,
    "TargetHeightPx": 1200,
    "StopThresholdMinutes": 30,
    "AddFinalSummaryMap": true,
    "CustomTileUrlTemplate": null
  }
}
